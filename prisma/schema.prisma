generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  nombre    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Noticia {
  id               String   @id @default(cuid())
  titulo_es        String
  linkedinEmbedUrl String
  publicada        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Division {
  id              String          @id @default(cuid())
  nameEs          String
  nameEn          String?
  nameDe          String?
  descriptionEs   String?
  descriptionEn   String?
  descriptionDe   String?
  unidadesNegocio UnidadNegocio[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model UnidadNegocio {
  id         String   @id @default(cuid())
  nameEs     String
  nameEn     String?
  nameDe     String?
  location   String
  orden      Int      @default(0)
  activa     Boolean  @default(true)
  divisionId String
  division   Division @relation(fields: [divisionId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model MensajeContacto {
  id            String   @id @default(cuid())
  nombre        String
  email         String
  razonContacto String
  mensaje       String
  leido         Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model ContenidoSitio {
  id        String   @id
  seccion   String
  campo     String
  valor_es  String
  valor_en  String?
  valor_de  String?
  updatedAt DateTime @updatedAt
}

model ImagenSitio {
  id        String   @id @default(cuid())
  seccion   String
  nombre    String
  filename  String
  url       String
  createdAt DateTime @default(now())
}

model Evento {
  id          String   @id @default(cuid())
  titulo      String
  descripcion String?
  fecha       String
  lugar       String
  industria   String?
  url         String?
  imagenUrl   String?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Lead {
  id              String   @id @default(cuid())
  tipo            String   // cliente|proveedor|bolsa|alianza|etc
  productos       String?  // JSON array de selecciones
  mercado         String?  // JSON array
  volumen         String?
  nombre          String
  empresa         String?
  email           String
  whatsapp        String?
  comentarios     String?
  createdAt       DateTime @default(now())
  leido           Boolean  @default(false)
}

model ClienteLogo {
  id        String   @id @default(cuid())
  nombre    String
  url       String
  filename  String
  orden     Int      @default(0)
  createdAt DateTime @default(now())
}