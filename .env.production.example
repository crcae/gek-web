# Variables de entorno — Producción
# Copiar este archivo como .env.production y rellenar los valores

# ─── Base de datos — Supabase PostgreSQL ───────────────────────────────────────
# Ir a supabase.com → tu proyecto → Settings → Database → Connection string
# Seleccionar "Transaction" mode (puerto 6543 — recomendado para Vercel serverless)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres"

# ─── NextAuth ──────────────────────────────────────────────────────────────────
# Generar secret: openssl rand -base64 32
NEXTAUTH_SECRET="pegar-secret-generado-aqui"
NEXTAUTH_URL="https://www.grupoexportadordelcampo.com"

# ─── Vercel Blob Storage ───────────────────────────────────────────────────────
# Se genera automáticamente al activar Blob en Vercel Dashboard
# Vercel proyecto → Storage → Create Database → Blob
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxx"

# ─── Resend — Emails ───────────────────────────────────────────────────────────
# Ir a resend.com → API Keys → Create API Key
RESEND_API_KEY="re_xxxxxxxxxxxx"
# Email donde llegan los mensajes del formulario de contacto
EMAIL_DESTINO="contacto@grupoexportadordelcampo.com"

# ─── Admin inicial (solo para seed) ───────────────────────────────────────────
ADMIN_EMAIL="admin@grupoexportadordelcampo.com"
ADMIN_PASSWORD="GEK2026-cambiar-tras-primer-login!"
